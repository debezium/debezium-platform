    "type": "GOOGLE_PUB_SUB",
    "schema": {
      "title": "Google Cloud Pub/Sub connection properties",
      "description": "Properties required to connect to Google Cloud Pub/Sub. Credentials can be supplied via a service account JSON key file, inline JSON key content, or omitted entirely to rely on Application Default Credentials (ADC).",
      "type": "object",
      "required": [
        "project.id"
      ],
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "project.id": {
          "type": "string",
          "title": "GCP Project ID (e.g. my-gcp-project)"
        },
        "credentials.file.path": {
          "type": "string",
          "title": "Absolute path to a GCP service account JSON key file (optional, mutually exclusive with credentials.json)"
        },
        "credentials.json": {
          "type": "string",
          "title": "Inline GCP service account JSON key content (optional, mutually exclusive with credentials.file.path)"
        },
        "endpoint": {
          "type": "string",
          "title": "Custom gRPC endpoint, e.g. localhost:8085 when using the Pub/Sub Emulator (optional)"
        }
      }
    }  }
