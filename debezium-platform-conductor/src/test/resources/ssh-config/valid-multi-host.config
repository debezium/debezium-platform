# Test fixture — valid multi-host SSH config
Host *
    ServerAliveInterval 60

Host db-server-1
    HostName 192.168.1.10
    User ubuntu
    Port 22
    IdentityFile ~/.ssh/db-server-1.key

Host db-server-2
    HostName 192.168.1.20
    User deploy
    Port 2222
    IdentityFile ~/.ssh/db-server-2.key
